FLASK_ENV=development
FLASK_DEBUG=false

# Security
SECRET_KEY=change_me_generate_new_secret_with_python_c_secrets_token_hex_32

# Database
DATABASE_URL=postgresql+psycopg2://postgres:CHANGE_THIS_PASSWORD@localhost:5432/dbname?sslmode=require

# Uploads & storage
UPLOAD_FOLDER=/absolute/path/to/uploads
DATADUMP_UPLOAD_FOLDER=/absolute/path/to/datadump/uploads
DATADUMP_GENERATED_FOLDER=/absolute/path/to/datadump/generated
USER_UPLOADED_FOLDER=/absolute/path/to/user/uploads

# Session / cookies
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=28800

# File size limits (bytes)
MAX_CONTENT_LENGTH=64424509440

# Embeddings / vector search
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=
EMBEDDING_CACHE_SIZE=5000
EMBEDDING_PRELOAD=true
EMBEDDING_BATCH_SIZE=20
UPLOAD_MAX_ROWS=1000
VECTOR_SEARCH_LIMIT=50
SIMILARITY_THRESHOLD=0.75
SUGGESTION_SIMILARITY_THRESHOLD=0.65
SUGGESTION_MIN_MARGIN=0.02

# HuggingFace offline configuration (for air-gapped deployment)
# Run download_huggingface_models.py in a connected environment first
# Then set this to the copied cache directory path
TRANSFORMERS_CACHE=C:/path/to/huggingface/cache

# MIME types
UPLOAD_ALLOWED_MIME_TYPES=text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel
DATADUMP_ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document
DOCUMENT_ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain,text/markdown,text/csv

# Portal version
PORTAL_VERSION=1.0.0

# Rate Limiting
RATELIMIT_STORAGE_URL=memory://
RATELIMIT_DEFAULT=200 per day, 50 per hour
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated list of allowed origins, use * only for development)
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Monitoring
ENABLE_METRICS=false
METRICS_PORT=9090

# Email Configuration
MAIL_SERVER=localhost
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=AMS Portal <noreply@ams.local>

# Notification Settings
NOTIFICATION_ENABLED=true
COMMITMENT_REMINDER_DAYS=7

# Document Management Configuration
DOCUMENT_ENCRYPTION_KEY=generate_with_python_c_secrets_token_hex_32
ANTHROPIC_API_KEY=your_anthropic_api_key_if_using_claude
MAX_FILE_SIZE_MB=20
TOP_K_CHUNKS=5
DOCUMENT_SIMILARITY_THRESHOLD=0.72
AUDIT_SALT=generate_with_python_c_secrets_token_hex_32_for_audit_logging
ERASURE_SECRET=generate_with_python_c_secrets_token_hex_32_for_gdpr_compliance

# Production Server Configuration
FLASK_ENV=production
FLASK_DEBUG=false
GUNICORN_BIND=0.0.0.0:5000
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120

# Initial Admin Setup
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_NAME=Administrator
INITIAL_ADMIN_STATE=Default
INITIAL_ADMIN_PASSWORD=CHANGE_THIS_PASSWORD

# Test Configuration
TEST_USER_PASSWORD=CHANGE_THIS_PASSWORD

# Celery Configuration (Optional - for background tasks)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
